"""
Testy zaawansowane dla modułu scanner.py.
"""

import os
import sys
import unittest
import tempfile
import shutil
from pathlib import Path
import time
from threading import Thread, Event

# Import testowanego modułu
sys.path.append(str(Path(__file__).parent.parent.parent))
from src.logic.scanner import (
    collect_files,
    create_file_pairs, 
    scan_folder_for_pairs,
    ScanningInterrupted,
    clear_cache,
)
from src.models.file_pair import FilePair


class TestScannerAdvanced(unittest.TestCase):
    """Testy zaawansowane dla modułu scanner."""
    
    def setUp(self):
        """Przygotowanie środowiska testowego."""
        # Tworzymy tymczasowy katalog
        self.test_dir = tempfile.mkdtemp()
        
        # Struktura testowa:
        # - Wielopoziomowa struktura katalogów
        # - Pliki z nazwami zawierającymi znaki Unicode
        # - Pliki z nazwami różniącymi się tylko wielkością liter
        # - Wiele par plików z tą samą nazwą bazową
        
        # Tworzymy strukturę katalogów
        self.subdir1 = os.path.join(self.test_dir, "poziom1")
        self.subdir2 = os.path.join(self.subdir1, "poziom2")
        self.subdir3 = os.path.join(self.subdir2, "poziom3")
        self.subdir4 = os.path.join(self.test_dir, "poziom1_równoległy")
        
        for directory in [self.subdir1, self.subdir2, self.subdir3, self.subdir4]:
            os.makedirs(directory)
        
        # Tworzymy pliki testowe
        self.create_test_files()
        
        # Czyścimy bufor przed każdym testem
        clear_cache()
    
    def tearDown(self):
        """Sprzątanie po testach."""
        # Usuwamy tymczasowy katalog
        shutil.rmtree(self.test_dir)
    
    def create_test_files(self):
        """Tworzy pliki testowe w katalogach testowych."""
        # Pliki z Unicode w nazwach
        self.file_unicode_archive = os.path.join(self.test_dir, "żółć.step")
        self.file_unicode_preview = os.path.join(self.test_dir, "żółć.png")
        
        # Pliki różniące się tylko wielkością liter
        self.file_case1 = os.path.join(self.test_dir, "CaseSensitive.step")
        self.file_case2 = os.path.join(self.test_dir, "casesensitive.png")
        
        # Wiele par plików z tą samą nazwą bazową
        self.file_multi1_arch1 = os.path.join(self.subdir1, "multi.step")
        self.file_multi1_arch2 = os.path.join(self.subdir1, "multi.stl")
        self.file_multi1_prev1 = os.path.join(self.subdir1, "multi.png")
        self.file_multi1_prev2 = os.path.join(self.subdir1, "multi.jpg")
        
        # Pliki w głębszych katalogach
        self.file_deep_archive = os.path.join(self.subdir3, "deep.step")
        self.file_deep_preview = os.path.join(self.subdir3, "deep.png")
        
        # Pliki w równoległych katalogach
        self.file_parallel_archive = os.path.join(self.subdir4, "parallel.step")
        self.file_parallel_preview = os.path.join(self.subdir4, "parallel.png")
        
        # Tworzymy puste pliki
        all_files = [
            self.file_unicode_archive, self.file_unicode_preview,
            self.file_case1, self.file_case2,
            self.file_multi1_arch1, self.file_multi1_arch2,
            self.file_multi1_prev1, self.file_multi1_prev2,
            self.file_deep_archive, self.file_deep_preview,
            self.file_parallel_archive, self.file_parallel_preview,
        ]
        
        for file_path in all_files:
            with open(file_path, "w") as f:
                f.write("test content")
    
    def test_unicode_file_names(self):
        """Test obsługi plików z nazwami zawierającymi znaki Unicode."""
        # Zbieramy pliki
        file_map = collect_files(self.test_dir)
        
        # Tworzymy pary
        pairs, _ = create_file_pairs(file_map, self.test_dir)
        
        # Szukamy pary z nazwami Unicode
        unicode_pair = next(
            (p for p in pairs if p.archive_path == self.file_unicode_archive),
            None
        )
        
        # Sprawdzamy czy para została utworzona
        self.assertIsNotNone(unicode_pair)
        self.assertEqual(unicode_pair.archive_path, self.file_unicode_archive)
        self.assertEqual(unicode_pair.preview_path, self.file_unicode_preview)
    
    def test_case_insensitive_pairing(self):
        """Test parowania plików, których nazwy różnią się tylko wielkością liter."""
        # Zbieramy pliki
        file_map = collect_files(self.test_dir)
        
        # Tworzymy pary
        pairs, _ = create_file_pairs(file_map, self.test_dir)
        
        # Szukamy pary z nazwami różniącymi się wielkością liter
        case_pair = next(
            (p for p in pairs if p.archive_path == self.file_case1),
            None
        )
        
        # Sprawdzamy czy para została utworzona
        self.assertIsNotNone(case_pair)
        self.assertEqual(case_pair.archive_path, self.file_case1)
        self.assertEqual(case_pair.preview_path, self.file_case2)
    
    def test_multiple_files_same_base_name(self):
        """Test parowania wielu plików z tą samą nazwą bazową."""
        # Skanujemy katalog z opcją pair_all=True (domyślnie)
        pairs, _, _ = scan_folder_for_pairs(self.subdir1)
        
        # Powinny być 4 pary (2 archiwa × 2 podglądy)
        self.assertEqual(len(pairs), 4)
        
        # Sprawdzamy wszystkie kombinacje
        expected_combinations = [
            (self.file_multi1_arch1, self.file_multi1_prev1),
            (self.file_multi1_arch1, self.file_multi1_prev2),
            (self.file_multi1_arch2, self.file_multi1_prev1),
            (self.file_multi1_arch2, self.file_multi1_prev2),
        ]
        
        for arch, prev in expected_combinations:
            self.assertTrue(
                any(p.archive_path == arch and p.preview_path == prev for p in pairs),
                f"Nie znaleziono pary ({arch}, {prev})"
            )
        
        # Teraz skanujemy z opcją pair_all=False
        pairs, _, _ = scan_folder_for_pairs(self.subdir1, pair_all=False)
        
        # Powinna być tylko 1 para
        self.assertEqual(len(pairs), 1)
    
    def test_max_depth_scanning(self):
        """Test skanowania z różnymi ograniczeniami głębokości."""
        # Głębokość 0 (tylko główny katalog)
        pairs0, _, _ = scan_folder_for_pairs(self.test_dir, max_depth=0)
        
        # Powinny być 2 pary z głównego katalogu
        self.assertEqual(len(pairs0), 2)  # Unicode i CaseSensitive
        
        # Głębokość 1 (główny katalog + pierwszy poziom podkatalogów)
        pairs1, _, _ = scan_folder_for_pairs(self.test_dir, max_depth=1)
        
        # Powinny być 2 pary z głównego katalogu + 4 pary z subdir1 (multi files) + 1 para z subdir4
        self.assertEqual(len(pairs1), 7)
        
        # Głębokość 3 (wszystkie katalogi)
        pairs3, _, _ = scan_folder_for_pairs(self.test_dir, max_depth=3)
        
        # Wszystkie 8 par
        self.assertEqual(len(pairs3), 8)  # 2 + 4 + 1 + 1
    
    def test_interrupt_scanning(self):
        """Test mechanizmu przerwania skanowania."""
        # Tworzymy katalog z wieloma plikami dla dłuższego skanowania
        large_dir = os.path.join(self.test_dir, "large_dir")
        os.makedirs(large_dir)
        
        # Tworzymy 100 par plików
        for i in range(100):
            with open(os.path.join(large_dir, f"file{i}.step"), "w") as f:
                f.write("test content")
            with open(os.path.join(large_dir, f"file{i}.png"), "w") as f:
                f.write("test content")
        
        # Przerwanie po znalezieniu 10 plików
        files_count = [0]
        stop_event = Event()
        
        def interrupt_check():
            files_count[0] += 1
            if files_count[0] >= 10:
                return True
            return False
        
        # Powinno rzucić wyjątek ScanningInterrupted
        with self.assertRaises(ScanningInterrupted):
            scan_folder_for_pairs(large_dir, interrupt_check=interrupt_check)
    
    def test_concurrent_scanning(self):
        """Test równoczesnego skanowania w wielu wątkach."""
        # Tworzymy kilka katalogów do skanowania
        test_dirs = []
        for i in range(3):
            new_dir = os.path.join(self.test_dir, f"concurrent_{i}")
            os.makedirs(new_dir)
            
            # Tworzymy parę plików w każdym katalogu
            with open(os.path.join(new_dir, "file.step"), "w") as f:
                f.write("test content")
            with open(os.path.join(new_dir, "file.png"), "w") as f:
                f.write("test content")
                
            test_dirs.append(new_dir)
        
        # Wyniki skanowania
        results = [None] * len(test_dirs)
        
        # Funkcja skanowania dla wątku
        def scan_thread(index):
            try:
                result = scan_folder_for_pairs(test_dirs[index])
                results[index] = result
            except Exception as e:
                results[index] = e
        
        # Uruchamiamy równoczesne skanowanie w wielu wątkach
        threads = []
        for i in range(len(test_dirs)):
            t = Thread(target=scan_thread, args=(i,))
            threads.append(t)
            t.start()
        
        # Czekamy na zakończenie wszystkich wątków
        for t in threads:
            t.join()
        
        # Sprawdzamy wyniki
        for i, result in enumerate(results):
            self.assertIsInstance(result, tuple)
            pairs, _, _ = result
            self.assertEqual(len(pairs), 1, f"Błąd w wątku {i}")
    
    def test_relative_paths_in_file_pair(self):
        """Test tworzenia FilePair z różnymi rodzajami ścieżek."""
        # Zbieramy pliki
        file_map = collect_files(self.test_dir)
        
        # Tworzymy pary z absolutną ścieżką bazową
        pairs_abs, _ = create_file_pairs(file_map, os.path.abspath(self.test_dir))
        
        # Tworzymy pary z względną ścieżką bazową
        # Najpierw zmieniamy katalog roboczy, aby względna ścieżka miała sens
        orig_dir = os.getcwd()
        parent_dir = os.path.dirname(self.test_dir)
        os.chdir(parent_dir)
        
        # Teraz używamy względnej ścieżki
        rel_path = os.path.basename(self.test_dir)
        pairs_rel, _ = create_file_pairs(file_map, rel_path)
        
        # Przywracamy oryginalny katalog roboczy
        os.chdir(orig_dir)
        
        # Sprawdzamy czy pary zostały utworzone
        self.assertEqual(len(pairs_abs), len(pairs_rel))
        
        # Sprawdzamy czy ścieżki bazowe są poprawnie ustawione
        pair_abs = next(iter(pairs_abs))
        pair_rel = next(iter(pairs_rel))
        
        self.assertEqual(pair_abs.base_dir, os.path.abspath(self.test_dir))
        self.assertEqual(pair_rel.base_dir, rel_path)


if __name__ == "__main__":
    unittest.main()
